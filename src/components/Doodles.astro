---
import {
  Wheat,
  Beer,
  UtensilsCrossed,
  Leaf,
  Beef,
  Drumstick,
  Soup,
  CakeSlice,
  Wine,
  Coffee,
  Apple,
  Cherry,
  Heart,
  Sparkles,
  Flower,
  Trees,
  CookingPot,
  Croissant,
  Salad,
  Grape,
  Star,
  GlassWater,
  Fish,
} from "lucide-astro";
---

<div
  class="pointer-events-none absolute inset-0 overflow-hidden z-0"
  aria-hidden="true"
>
  <Leaf
    class="absolute top-20 left-10 w-32 h-32 text-emerald-900 opacity-[0.10] -rotate-12"
  />
  <Wheat
    class="absolute top-1/4 right-12 w-40 h-40 text-emerald-900 opacity-[0.10] rotate-12"
  />
  <UtensilsCrossed
    class="absolute top-[60%] left-16 w-28 h-28 text-emerald-900 opacity-[0.10] -rotate-6"
  />
  <Beer
    class="absolute bottom-32 right-20 w-32 h-32 text-emerald-900 opacity-[0.10] rotate-45"
  />

  <Beer
    class="absolute top-[10%] left-[40%] w-24 h-24 text-stone-800 opacity-[0.08] rotate-[110deg]"
  />
  <Wheat
    class="absolute bottom-[20%] left-[30%] w-36 h-36 text-stone-800 opacity-[0.08] -rotate-[25deg]"
  />
  <Leaf
    class="absolute top-[50%] right-[10%] w-28 h-28 text-stone-800 opacity-[0.08] rotate-[70deg]"
  />
  <UtensilsCrossed
    class="absolute bottom-[10%] right-[40%] w-24 h-24 text-stone-800 opacity-[0.08] rotate-[15deg]"
  />

  <Beef
    class="absolute top-[5%] right-[30%] w-20 h-20 text-stone-700 opacity-[0.08] -rotate-[20deg]"
  />
  <Drumstick
    class="absolute top-[35%] left-[50%] w-16 h-16 text-amber-900 opacity-[0.08] rotate-[35deg]"
  />
  <Soup
    class="absolute top-[75%] right-[35%] w-22 h-22 text-emerald-900 opacity-[0.10] rotate-[12deg]"
  />
  <CakeSlice
    class="absolute top-[15%] left-[60%] w-18 h-18 text-amber-800 opacity-[0.08] rotate-[25deg]"
  />
  <Wine
    class="absolute bottom-[35%] right-[5%] w-20 h-20 text-rose-900 opacity-[0.10] -rotate-[8deg]"
  />
  <Coffee
    class="absolute top-[55%] left-[5%] w-20 h-20 text-stone-800 opacity-[0.08] rotate-[18deg]"
  />
  <Apple
    class="absolute top-[8%] left-[55%] w-14 h-14 text-red-900 opacity-[0.08] -rotate-[30deg]"
  />
  <Cherry
    class="absolute bottom-[15%] left-[55%] w-16 h-16 text-red-900 opacity-[0.08] rotate-[22deg]"
  />
  <Heart
    class="absolute top-[30%] right-[22%] w-12 h-12 text-rose-800 opacity-[0.10] rotate-[15deg]"
  />
  <Heart
    class="absolute bottom-[40%] left-[20%] w-10 h-10 text-rose-800 opacity-[0.08] -rotate-[10deg]"
  />
  <Sparkles
    class="absolute top-[2%] left-[25%] w-12 h-12 text-amber-600 opacity-[0.10] rotate-[5deg]"
  />
  <Sparkles
    class="absolute bottom-[5%] right-[55%] w-10 h-10 text-amber-600 opacity-[0.08] rotate-[40deg]"
  />
  <Flower
    class="absolute top-[70%] right-[15%] w-16 h-16 text-emerald-800 opacity-[0.10] rotate-[30deg]"
  />
  <Flower
    class="absolute top-[25%] left-[75%] w-14 h-14 text-emerald-800 opacity-[0.08] -rotate-[15deg]"
  />
  <Trees
    class="absolute bottom-[2%] left-[70%] w-24 h-24 text-emerald-900 opacity-[0.08]"
  />
  <CookingPot
    class="absolute top-[45%] left-[35%] w-20 h-20 text-stone-700 opacity-[0.08] rotate-[-12deg]"
  />
  <Croissant
    class="absolute top-[20%] left-[15%] w-16 h-16 text-amber-800 opacity-[0.08] rotate-[8deg]"
  />
  <Salad
    class="absolute bottom-[25%] right-[25%] w-18 h-18 text-emerald-800 opacity-[0.08] -rotate-[18deg]"
  />
  <Grape
    class="absolute top-[65%] right-[45%] w-14 h-14 text-purple-900 opacity-[0.08] rotate-[-5deg]"
  />
  <Star
    class="absolute top-[40%] right-[50%] w-10 h-10 text-amber-500 opacity-[0.10] rotate-[20deg]"
  />
  <Star
    class="absolute bottom-[45%] left-[65%] w-8 h-8 text-amber-500 opacity-[0.08] -rotate-[25deg]"
  />
  <GlassWater
    class="absolute top-[55%] right-[35%] w-16 h-16 text-sky-900 opacity-[0.08] rotate-[10deg]"
  />
  <Fish
    class="absolute bottom-[30%] left-[85%] w-16 h-16 text-sky-800 opacity-[0.08] -rotate-[12deg]"
  />
  <Grape
    class="absolute top-[85%] left-[12%] w-12 h-12 text-purple-900 opacity-[0.08] rotate-[18deg]"
  />
  <Croissant
    class="absolute bottom-[55%] right-[55%] w-14 h-14 text-amber-800 opacity-[0.08] rotate-[35deg]"
  />
  <Beef
    class="absolute top-[12%] right-[70%] w-14 h-14 text-stone-700 opacity-[0.08] rotate-[45deg]"
  />
  <Flower
    class="absolute bottom-[18%] left-[45%] w-14 h-14 text-emerald-800 opacity-[0.08] rotate-[-28deg]"
  />
</div>