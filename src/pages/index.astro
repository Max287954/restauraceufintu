---
import { Image } from "astro:assets";
import Layout from "@components/Layout.astro";
import { siteConfig } from "@data/profile";
import BackgroundDoodles from "@components/BackgroundDoodles.astro";

const pageDescription = `${siteConfig.name} v Habartově — poctivá česká kuchyně, denní menu a příjemné posezení. Otevřeno každý den.`;

const mapsEmbedUrl =
  "https://maps.google.com/maps?q=1.%20M%C3%A1je%20178,%2035709%20Habartov,%20CZ&t=&z=16&ie=UTF8&iwloc=&output=embed";
---

<Layout
  title="Domů"
  description={pageDescription}
  canonical="/"
>
  <!-- Hero Section -->
  <section class="relative bg-organic min-h-[85vh] flex items-center">
    <div class="bg-blob-left"></div>
    <div class="bg-blob-right"></div>
    <BackgroundDoodles />
    <div class="section-container relative z-10 py-20 md:py-32 w-full">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text -->
        <div class="max-w-xl">
          <span class="inline-block text-terracotta font-medium text-sm uppercase tracking-widest mb-4">
            Vítejte v Habartově
          </span>
          <h1 class="text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-warm-brown leading-tight mb-6">
            Restaurace<br class="sm:hidden" /> Na Truhlárně
          </h1>
          <p class="text-lg md:text-xl text-warm-brown/70 max-w-lg mb-10 leading-relaxed">
            Poctivá česká kuchyně, čepované pivo a příjemné posezení v srdci
            Habartova. Vaříme s láskou z čerstvých surovin každý den.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/denni-menu/" class="btn-primary text-lg">
              Dnešní denní menu
            </a>
            <a href="/jidelnistek/" class="btn-secondary text-lg">
              Jídelní lístek
            </a>
          </div>
        </div>
        <!-- Right: Hero Image -->
        <div class="hidden lg:block">
          <Image
            src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?w=800&h=600&fit=crop&q=80"
            alt="Vnitřek restaurace s prostřenými stoly"
            width={800}
            height={600}
            class="rounded-[2rem] shadow-2xl object-cover w-full h-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section class="section-padding relative" id="o-nas">
    <div class="bg-blob-right" style="top: 10%; left: auto; right: -5%"></div>
    <BackgroundDoodles />
    <div class="section-container relative z-10">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="text-olive font-medium text-sm uppercase tracking-widest">
            O nás
          </span>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-warm-brown mt-3 mb-6">
            Vítejte u nás
          </h2>
          <p class="text-warm-brown/70 leading-relaxed mb-4">
            Restaurace Na Truhlárně je místo, kde se setkává tradice s moderním
            přístupem ke gastronomii. Majitel a šéfkuchař Jaroslav Šindelář se
            svým týmem denně připravuje poctivá jídla z čerstvých, převážně
            lokálních surovin.
          </p>
          <p class="text-warm-brown/70 leading-relaxed mb-4">
            Naše kuchyně staví na osvědčených českých recepturách, které
            doplňujeme sezónními specialitami. Vždy u nás najdete širokou
            nabídku hotových jídel, denní menu a perfektně ošetřené pivo.
          </p>
          <p class="text-warm-brown/70 leading-relaxed">
            Ať už se stavíte na oběd, večeři, nebo jen na pivo s přáteli, u nás
            se budete cítit jako doma.
          </p>
        </div>
        <!-- Masonry Image Grid for "O nás" -->
        <div class="relative">
          <div class="grid grid-cols-2 gap-3">
            <Image
              src="https://images.unsplash.com/photo-1579027989536-b7b1f875659b?q=80&w=800&auto=format&fit=crop"
              alt="České pivo v restauraci"
              width={400}
              height={400}
              class="w-full h-full object-cover aspect-square rounded-xl shadow-lg"
            />
            <Image
              src="https://images.unsplash.com/photo-1604908176997-125f25cc6f3d?q=80&w=800&auto=format&fit=crop"
              alt="Plný talíř českého jídla"
              width={400}
              height={400}
              class="w-full h-full object-cover aspect-square rounded-xl shadow-lg"
            />
            <Image
              src="https://images.unsplash.com/photo-1599921841143-819065a55cc6?q=80&w=800&auto=format&fit=crop"
              alt="Svíčková na smetaně"
              width={400}
              height={400}
              class="w-full h-full object-cover aspect-square rounded-xl shadow-lg"
            />
            <Image
              src="https://images.unsplash.com/photo-1514933651103-005eec06c04b?q=80&w=800&auto=format&fit=crop"
              alt="Čepované pivo zblízka"
              width={400}
              height={400}
              class="w-full h-full object-cover aspect-square rounded-xl shadow-lg"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Google Maps & Contact -->
  <section class="section-padding relative" id="kontakt">
    <div class="bg-blob-left"></div>
    <BackgroundDoodles />
    <div class="section-container relative z-10">
      <div class="text-center mb-12">
        <span class="text-olive font-medium text-sm uppercase tracking-widest">
          Kde nás najdete
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-warm-brown mt-3">
          Kontakt a mapa
        </h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="card space-y-4">
          <h3 class="font-heading text-xl font-semibold text-warm-brown">
            {siteConfig.name}
          </h3>
          <address class="not-italic text-warm-brown/70 space-y-1">
            <p>{siteConfig.address.street}</p>
            <p>{siteConfig.address.postalCode} {siteConfig.address.city}</p>
          </address>
          <p class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-terracotta">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a
              href={`tel:${siteConfig.owner.phone}`}
              class="text-terracotta hover:text-terracotta-dark underline underline-offset-2 transition-colors"
            >
              {siteConfig.owner.phone}
            </a>
          </p>
          <p class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="text-terracotta">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a
              href={`mailto:${siteConfig.owner.email}`}
              class="text-terracotta hover:text-terracotta-dark underline underline-offset-2 transition-colors"
            >
              {siteConfig.owner.email}
            </a>
          </p>
          <div>
            <h4 class="font-medium text-warm-brown mb-1">Otevírací doba</h4>
            <ul class="text-sm text-warm-brown/70 space-y-0.5">
              {Object.entries(siteConfig.openingHours).map(([_, day]) => (
                <li>
                  {day.label}: {day.open}–{day.close}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="rounded-[2rem] overflow-hidden shadow-xl h-[350px] md:h-full min-h-[350px]">
          <iframe
            title="Restaurace Na Truhlárně — mapa"
            src={mapsEmbedUrl}
            width="100%"
            height="100%"
            style="border:0"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</Layout>