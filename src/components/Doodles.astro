---
import { Wheat, Beer, UtensilsCrossed, Leaf } from "lucide-astro";
---

<div
  class="pointer-events-none absolute inset-0 overflow-hidden z-0"
  aria-hidden="true"
>
  <Leaf
    class="absolute top-20 left-10 w-32 h-32 text-emerald-900 opacity-[0.04] -rotate-12"
  />
  <Wheat
    class="absolute top-1/4 right-12 w-40 h-40 text-emerald-900 opacity-[0.04] rotate-12"
  />
  <UtensilsCrossed
    class="absolute top-[60%] left-16 w-28 h-28 text-emerald-900 opacity-[0.04] -rotate-6"
  />
  <Beer
    class="absolute bottom-32 right-20 w-32 h-32 text-emerald-900 opacity-[0.04] rotate-45"
  />

  <Beer
    class="absolute top-[10%] left-[40%] w-24 h-24 text-stone-800 opacity-[0.03] rotate-[110deg]"
  />
  <Wheat
    class="absolute bottom-[20%] left-[30%] w-36 h-36 text-stone-800 opacity-[0.03] -rotate-[25deg]"
  />
  <Leaf
    class="absolute top-[50%] right-[10%] w-28 h-28 text-stone-800 opacity-[0.03] rotate-[70deg]"
  />
  <UtensilsCrossed
    class="absolute bottom-[10%] right-[40%] w-24 h-24 text-stone-800 opacity-[0.03] rotate-[15deg]"
  />
</div>