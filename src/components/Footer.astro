---
import { siteConfig } from "@data/profile";

const currentYear = new Date().getFullYear();
---

<footer class="bg-warm-brown-dark text-cream mt-auto overflow-hidden relative">
  <div class="section-container section-padding relative z-10">
    <div class="grid md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <span class="font-heading text-xl font-semibold text-white">
          {siteConfig.name}
        </span>
        <p class="mt-3 text-cream/70 text-sm leading-relaxed">
          Klasická lokální restaurace s kvalitním jídlem v Krajkové. Tradice, poctivost a příjemné
          posezení pod jednou střechou.
        </p>
      </div>

      <!-- Opening hours -->
      <div>
        <h3 class="font-heading text-base font-semibold text-white mb-3">Otevírací doba</h3>
        <ul class="space-y-1 text-sm text-cream/70" role="list">
          {
            Object.entries(siteConfig.openingHours).map(([_key, day]) => (
              <li class="flex justify-between gap-4">
                <span>{day.label}</span>
                <span class="text-cream/90">
                  {day.open}–{day.close}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-heading text-base font-semibold text-white mb-3">Kontakt</h3>
        <address class="not-italic text-sm text-cream/70 space-y-1">
          <p>{siteConfig.address.street}</p>
          <p>{siteConfig.address.city}, {siteConfig.address.postalCode}</p>
          <p class="mt-2 flex items-center gap-1.5">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="text-cream/50"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path>
            </svg>
            <a
              href={`tel:${siteConfig.owner.phone}`}
              class="text-cream/80 hover:text-terracotta-light transition-colors underline underline-offset-2"
            >
              {siteConfig.owner.phone}
            </a>
          </p>
          <p class="flex items-center gap-1.5">
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              class="text-cream/50"
            >
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <a
              href={`mailto:${siteConfig.owner.email}`}
              class="text-cream/80 hover:text-terracotta-light transition-colors underline underline-offset-2"
            >
              {siteConfig.owner.email}
            </a>
          </p>
        </address>
      </div>
    </div>

    <!-- Legal Block -->
    <div class="mt-12 pt-8 border-t border-cream/15 text-xs text-cream/50 space-y-2">
      <!-- TODO: Replace placeholder registration details before launch -->
      <p>
        IČO: {siteConfig.owner.ico} | DIČ: {siteConfig.owner.dic} | {
          siteConfig.owner.registeredAddress
        }
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href="/zasady-ochrany-osobnich-udaju/"
          class="hover:text-cream/70 transition-colors underline underline-offset-2"
        >
          Zásady ochrany osobních údajů
        </a>
        <a
          href="/admin/"
          class="text-cream/30 hover:text-cream/50 transition-colors underline underline-offset-2"
        >
          Administrace
        </a>
      </div>
      <p>&copy; {currentYear} {siteConfig.name}. Všechna práva vyhrazena.</p>
    </div>
  </div>
</footer>
